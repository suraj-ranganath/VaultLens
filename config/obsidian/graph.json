{
  "collapse-filter": false,
  "search": "path:items OR path:topics OR path:projects OR path:dashboards",
  "showTags": false,
  "showAttachments": false,
  "hideUnresolved": true,
  "showOrphans": false,
  "collapse-color-groups": false,
  "colorGroups": [
    {
      "query": "path:items/jobs",
      "color": { "a": 1, "rgb": 12945088 }
    },
    {
      "query": "path:items/articles OR path:items/resources OR path:items/tweets",
      "color": { "a": 1, "rgb": 6986069 }
    },
    {
      "query": "path:items/thoughts OR path:items/reminders OR path:items/events",
      "color": { "a": 1, "rgb": 5227007 }
    },
    {
      "query": "path:items/decisions OR path:items/systems",
      "color": { "a": 1, "rgb": 13724009 }
    },
    {
      "query": "path:topics OR path:projects",
      "color": { "a": 1, "rgb": 5676246 }
    },
    {
      "query": "path:dashboards",
      "color": { "a": 1, "rgb": 4473924 }
    }
  ],
  "showArrow": true,
  "textFadeMultiplier": -1,
  "nodeSizeMultiplier": 1.8,
  "lineSizeMultiplier": 1,
  "centerStrength": 0.25,
  "repelStrength": 20,
  "linkStrength": 1,
  "linkDistance": 90,
  "scale": 0.8
}
