{
  "name": "vault-lens",
  "version": "1.0.0",
  "description": "Self-hosted, agent-maintained markdown knowledge base for personal capture, retrieval, surfacing, and decisions.",
  "main": "index.js",
  "scripts": {
    "vault:setup": "bash bin/setup-vault.sh",
    "vault:health": "python3 tools/vault_health.py",
    "vault:compile": "python3 tools/vault_compile_cache.py --vault-root .",
    "vault:dream": "python3 tools/vault_dream.py --vault-root .",
    "vault:search": "python3 tools/vault_search.py search --vault-root . --query",
    "vault:tasks": "python3 tools/vault_tasks.py sync-from-vault --vault-root .",
    "vault:heartbeat": "python3 tools/vault_heartbeat.py --vault-root .",
    "vault:trajectory": "python3 tools/vault_trajectory.py export --vault-root . --run-id",
    "x:fetch": "python3 tools/x_content.py",
    "test:vault-infra": "python3 -m unittest tools/test_vault_infra.py",
    "vault:web": "node tools/vault_query_server.mjs",
    "rebuild:dashboards": "python3 tools/rebuild_dashboards.py",
    "enrich:browser:recent": "node tools/enrich_with_browser.mjs . 120 4 30",
    "telegram:sync": "python3 tools/telegram_inbox.py sync --vault-root .",
    "telegram:run": "python3 tools/telegram_inbox.py run --vault-root .",
    "telegram:webhook:test": "python3 tools/telegram_inbox.py webhook --vault-root . --session-name telegram-webhook-test",
    "cloud:deploy": "bash cloud/deploy_telegram_webhook.sh",
    "cloud:sync-state": "bash cloud/sync_state_to_s3.sh",
    "test": "npm run test:vault-infra"
  },
  "keywords": [
    "personal-knowledge-base",
    "markdown",
    "obsidian",
    "telegram-bot",
    "aws-lambda",
    "agents",
    "retrieval"
  ],
  "author": "Suraj Ranganath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suraj-ranganath/VaultLens.git"
  },
  "bugs": {
    "url": "https://github.com/suraj-ranganath/VaultLens/issues"
  },
  "homepage": "https://github.com/suraj-ranganath/VaultLens#readme",
  "type": "commonjs",
  "dependencies": {
    "@googleworkspace/cli": "^0.22.5",
    "@openai/codex-sdk": "^0.134.0"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
